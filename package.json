{
  "name": "folder-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest test/unit.test.js --runInBand --forceExit --detectOpenHandles",
    "test:integration": "jest test/integration.test.js --runInBand --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "axios": "^1.6.0"
  },
  "jest": {
    "testEnvironment": "node",
    "detectOpenHandles": true,
    "forceExit": true,
    "clearMocks": true
  }
